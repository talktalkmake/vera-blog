---
import Layout from '../layouts/Layout.astro';
import { posts } from '../data/posts.js';

/**
 * URL PERMANENCE — READ BEFORE EDITING
 *
 * Once a post is published, its slug and filename are permanent.
 * The filename is the URL: 17-two-spreadsheets.astro → /vera-blog/posts/17-two-spreadsheets/
 * Breaking the filename breaks every link to that post.
 *
 * Safe: edit content, change title/description in frontmatter.
 * Never: rename a file, change a slug here, renumber existing posts, delete a post.
 * New posts: always append to src/data/posts.js with the next sequential number.
 * Redirects: if a URL ever must change, create a static HTML redirect at the old path.
 */

// Newest first
const sorted = [...posts].sort((a, b) => new Date(b.date) - new Date(a.date));
---
<Layout title="Build Log">
  <style>
    .intro {
      margin-bottom: 3.5rem;
    }

    .intro h1 {
      font-family: var(--font-sans);
      font-size: 2.25rem;
      font-weight: 700;
      margin: 0 0 1rem;
      line-height: 1.15;
    }

    .intro p {
      color: var(--muted);
      line-height: 1.75;
      max-width: 560px;
      margin: 0;
    }

    .post-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .post-item {
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 0 1.5rem;
      padding: 1.25rem 0;
      border-bottom: 1px solid var(--border);
      align-items: start;
    }

    .post-item:last-child {
      border-bottom: none;
    }

    .post-date {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--muted);
      white-space: nowrap;
      padding-top: 0.2rem;
    }

    .post-body {
      min-width: 0;
    }

    .post-titleline {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.3rem;
    }

    .post-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text);
      flex: 1;
      min-width: 0;
    }

    .post-title:hover {
      color: var(--accent);
      text-decoration: none;
    }

    .series-pill {
      font-family: var(--font-ui);
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 100px;
      padding: 0.2em 0.7em;
      white-space: nowrap;
      flex-shrink: 0;
      opacity: 0.75;
    }

    .post-desc {
      font-size: 0.83rem;
      color: var(--muted);
      margin: 0;
      line-height: 1.55;
    }

    .draft-tag {
      font-size: 0.7rem;
      color: var(--muted);
      margin-left: 0.4rem;
      font-family: var(--font-mono);
    }
  </style>

  <div class="intro">
    <h1>VERA Build Log</h1>
    <p>
      A retrospective development journal — the decisions, trade-offs, and
      thinking behind building VERA: a natural language time tracking and
      project intelligence tool for agencies.
    </p>
  </div>

  <ul class="post-list">
    {sorted.map(post => {
      const d = new Date(post.date + 'T00:00:00');
      const label = d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      return (
        <li class="post-item">
          <span class="post-date">{label}</span>
          <div class="post-body">
            <div class="post-titleline">
              <a href={`/vera-blog/posts/${post.slug}/`} class="post-title">
                {post.title}
                {post.draft && <span class="draft-tag">[draft]</span>}
              </a>
              <span class="series-pill">{post.series}</span>
            </div>
            <p class="post-desc">{post.description}</p>
          </div>
        </li>
      );
    })}
  </ul>
</Layout>
