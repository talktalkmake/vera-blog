---
import Layout from './Layout.astro';
import { posts } from '../data/posts.js';

export interface Props {
  title: string;
  date: string;
  description: string;
  series?: string;
  draft?: boolean;
}

const { title, date, description, series, draft } = Astro.props;

const formattedDate = new Date(date + 'T00:00:00').toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
});

// Derive slug from URL so individual post files don't need to pass it explicitly.
// URL pattern: /vera-blog/posts/{slug}/
const slug = Astro.url.pathname.split('/posts/')[1]?.replace(/\/$/, '') ?? '';

// Related posts: same series, excluding current, newest first
const related = series
  ? posts
      .filter(p => p.series === series && p.slug !== slug)
      .sort((a, b) => new Date(b.date) - new Date(a.date))
  : [];
---
<Layout title={title} description={description}>
  <style>
    .back {
      color: var(--muted);
      font-size: 0.85rem;
      margin-bottom: 2.5rem;
      display: block;
    }
    .back:hover { color: var(--accent); text-decoration: none; }

    .meta {
      margin-bottom: 2.5rem;
    }

    .meta-top {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .series-pill {
      font-family: var(--font-ui);
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 100px;
      padding: 0.2em 0.7em;
      white-space: nowrap;
      opacity: 0.75;
    }

    h1 {
      font-family: var(--font-sans);
      font-size: 2rem;
      font-weight: 700;
      line-height: 1.2;
      margin: 0 0 0.75rem;
      color: var(--text);
    }

    .date {
      color: var(--muted);
      font-size: 0.82rem;
    }

    .draft-banner {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      color: var(--muted);
      margin-bottom: 2rem;
      font-style: italic;
    }

    .content {
      line-height: 1.8;
      font-size: 1.05rem;
    }

    .content h2 {
      font-family: var(--font-sans);
      font-size: 1.3rem;
      margin-top: 2.5rem;
      color: var(--text);
    }
    .content h3 {
      font-family: var(--font-sans);
      font-size: 1.1rem;
      margin-top: 2rem;
    }
    .content p { margin: 1.25rem 0; }
    .content code {
      font-family: var(--font-mono);
      font-size: 0.85em;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 3px;
      padding: 0.15em 0.4em;
    }
    .content pre {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.25rem;
      overflow-x: auto;
      font-size: 0.85rem;
      line-height: 1.6;
    }
    .content pre code { background: none; border: none; padding: 0; }
    .content blockquote {
      border-left: 3px solid var(--accent);
      margin: 1.75rem 0;
      padding: 0.5rem 0 0.5rem 1.5rem;
      color: var(--muted);
      font-style: italic;
    }
    .content hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

    /* Related posts */
    .related {
      margin-top: 4rem;
      padding-top: 2.5rem;
      border-top: 1px solid var(--border);
    }

    .related-label {
      font-family: var(--font-ui);
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.25rem;
    }

    .related-post {
      display: block;
      padding: 0.9rem 0;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
    }

    .related-post:last-child {
      border-bottom: none;
    }

    .related-post:hover .related-title {
      color: var(--accent);
    }

    .related-title {
      display: block;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 0.25rem;
      transition: color 0.1s;
    }

    .related-desc {
      display: block;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.5;
    }
  </style>

  <a href="/vera-blog/" class="back">← All posts</a>

  <div class="meta">
    <div class="meta-top">
      {series && <span class="series-pill">{series}</span>}
      <span class="date">{formattedDate}</span>
    </div>
    <h1>{title}</h1>
  </div>

  {draft && (
    <div class="draft-banner">
      This post is a stub — full content coming soon.
    </div>
  )}

  <div class="content">
    <slot />
  </div>

  {related.length > 0 && (
    <div class="related">
      <div class="related-label">More from {series}</div>
      {related.map(p => (
        <a href={`/vera-blog/posts/${p.slug}/`} class="related-post">
          <span class="related-title">{p.title}</span>
          <span class="related-desc">{p.description}</span>
        </a>
      ))}
    </div>
  )}
</Layout>
